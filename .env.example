# ── Runtime ──────────────────────────────────────────────────────
APP_ENV=development                       # set to "production" when deployed
PORT=8080
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
TRANSCRIPT_SERVICE_URL=http://localhost:8081
FRONTEND_URL=http://localhost:3000        # used for OAuth callback redirects

# ── AWS ──────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2
# Provide credentials via `aws configure`, env vars, or an IAM role in prod:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48

# ── OAuth (optional) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URL=http://localhost:8080/auth/wechat/callback

# ── Seeder (cmd/seed) ────────────────────────────────────────────
# Run once to create the primary demo account:
#   go run ./cmd/seed
SEED_EMAIL=bosskero326@gmail.com
SEED_PASSWORD=replace-with-a-strong-password
SEED_FIRST_NAME=Boss
SEED_LAST_NAME=
